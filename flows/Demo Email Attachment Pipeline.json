{
  "name": "Demo Email Attachment Pipeline",
  "nodes": [
    { "id": "n_start", "type": "workflowNode", "position": { "x": 80, "y": 60 },  "data": { "nodeType": "start", "label": "Start" } },
    { "id": "n_read",  "type": "workflowNode", "position": { "x": 80, "y": 160 }, "data": { "nodeType": "readEmail", "label": "Read Email", "imapHost": "imap.gmail.com", "imapPort": "993", "secure": true, "username": "bot@example.com", "password": "{{secret.Mail.password}}", "folder": "INBOX", "unreadOnly": true, "limit": "10", "outputVariable": "emails" } },
    { "id": "n_for",   "type": "workflowNode", "position": { "x": 80, "y": 260 }, "data": { "nodeType": "forEachNode", "label": "For Each Email", "collection": "{{emails}}", "itemVariable": "item" } },
    { "id": "n_save",  "type": "workflowNode", "position": { "x": 360, "y": 360 }, "data": { "nodeType": "saveAttachment", "label": "Save Attachment", "emailVariable": "{{item}}", "saveDirectory": "C:\\inbox-files", "outputVariable": "savedFiles" } },
    { "id": "n_write", "type": "workflowNode", "position": { "x": 360, "y": 460 }, "data": { "nodeType": "writeFile", "label": "Log Saved", "filePath": "C:\\inbox-files\\log.txt", "content": "Saved: {{savedFiles}}" } },
    { "id": "n_mark",  "type": "workflowNode", "position": { "x": 360, "y": 560 }, "data": { "nodeType": "markEmailRead", "label": "Mark Read", "emailId": "{{item.id}}" } },
    { "id": "n_send",  "type": "workflowNode", "position": { "x": 80, "y": 680 }, "data": { "nodeType": "sendEmail", "label": "Send Summary", "smtpHost": "smtp.gmail.com", "smtpPort": "587", "secure": false, "username": "bot@example.com", "password": "{{secret.Mail.password}}", "from": "Bot <bot@example.com>", "to": "ops@example.com", "subject": "Inbox processed", "bodyType": "html", "body": "<p>Processed {{emails.length}} emails.</p>" } },
    { "id": "n_end",   "type": "workflowNode", "position": { "x": 80, "y": 780 }, "data": { "nodeType": "end", "label": "End", "autoCloseBrowser": true } }
  ],
  "edges": [
    { "id": "e1", "source": "n_start", "target": "n_read" },
    { "id": "e2", "source": "n_read",  "target": "n_for" },
    { "id": "e3", "source": "n_for",   "sourceHandle": "body", "target": "n_save" },
    { "id": "e4", "source": "n_save",  "target": "n_write" },
    { "id": "e5", "source": "n_write", "target": "n_mark" },
    { "id": "e6", "source": "n_for",   "sourceHandle": "done", "target": "n_send" },
    { "id": "e7", "source": "n_send",  "target": "n_end" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.85 }
}
