{
  "name": "manufactura-connect",
  "version": "1.0.0",
  "description": "Manufactura Connect - Visual RPA Workflow Designer & Automation Engine",
  "main": "apps/designer/electron/main.js",
  "author": "Manufactura",
  "license": "MIT",
  "scripts": {
    "dev:frontend": "cd apps/designer/frontend && npx vite --port 5173",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:frontend\" \"sleep 3 && npm run dev:electron\"",
    "build:frontend": "cd apps/designer/frontend && npx vite build",
    "build": "npm run build:frontend && npx electron-builder --win",
    "build:linux": "npm run build:frontend && npx electron-builder --linux",
    "install:frontend": "cd apps/designer/frontend && npm install"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "exceljs": "^4.4.0",
    "imapflow": "^1.4.2",
    "jimp": "^1.6.1",
    "mailparser": "^3.9.11",
    "nodemailer": "^6.10.1",
    "playwright": "^1.40.0",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.manufactura.connect",
    "productName": "Manufactura Connect",
    "directories": {
      "output": "dist"
    },
    "files": [
      "apps/designer/electron/**/*",
      "apps/designer/elementPicker.js",
      "apps/designer/frontend/dist/**/*",
      "apps/controller/**/*",
      "apps/robot/**/*",
      "shared/**/*",
      "flows/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "flows",
        "to": "flows",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "sidecar/dist",
        "to": "sidecar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Manufactura",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "signDlls": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Manufactura Connect"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
